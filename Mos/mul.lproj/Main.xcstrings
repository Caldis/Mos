    "TUE-3v-CaJ.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Rendering this chart will affect scrolling performance. Close the window when not in use.\"; ObjectID = \"TUE-3v-CaJ\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zobrazení tohoto grafu ovlivní výkon posouvání. Pokud jej nepoužíváte, zavřete okno."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Rendern dieses Diagramms wirkt sich auf die Bildlaufleistung aus. Schließen Sie das Fenster, wenn es nicht verwendet wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η απόδοση αυτού του γραφήματος θα επηρεάσει την απόδοση κύλισης. Κλείστε το παράθυρο όταν δεν χρησιμοποιείται."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Rendering this chart will affect scrolling performance. Close the window when not in use."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La génération de ce graphique impacte les performances du défilement. Fermez la fenêtre lorsque vous ne l’utilisez pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "グラフ表示はスクロールのパフォーマンスに影響します。使用しないときはウィンドウを閉じてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 차트를 랜더링 할때 스크롤링 성능에 영향을 줍니다. 사용하지 않을시엔 닫아주세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Визуализация этой диаграммы повлияет на производительность прокрутки. Закройте окно, когда оно не нужно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu grafiği işlemek, kaydırma performansını etkileyecektir. Kullanılmadığı zaman pencereyi kapatın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відображення цієї діаграми вплине на продуктивність прокручування. Закрийте вікно, коли не використовується."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "呈现该窗口的数据会显著影响滚动性能, 请仅在需要时开启"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "顯示視窗資訊對捲動效能會有顯著影響。請僅在必要時開啟"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "顯示視窗資訊對捲動效能會有顯著影響。請僅在必要時開啟"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "顯示視窗資訊對捲動效能會有顯著影響。請僅在必要時開啟"
          }
        }
      }
    },
