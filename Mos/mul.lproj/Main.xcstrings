    "Rgq-87-vjY.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Temporarily disable smooth scrolling to improve scrolling accuracy.\"; ObjectID = \"Rgq-87-vjY\";",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dočasně deaktivuje plynulé posouvání, aby se zlepšila přesnost posouvání."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glätten vorübergehend deaktivieren, um die Scrollgenauigkeit zu verbessern"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Απενεργοποιήστε προσωρινά την ομαλή κύλιση για βελτίωση της ακρίβειας κύλισης"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporarily disable smooth scrolling to improve scrolling accuracy"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactiver temporairement le défilement doux pour améliorer la précision du défilement"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スクロール精度を向上させるためにスムーズスクロールを一時的に無効化"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스크롤 정확도를 높이기 위해 부드러운 스크롤링을 일시적으로 비활성화"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Временно отключить плавную прокрутку для повышения точности прокрутки"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaydırma doğruluğunu artırmak için yumuşak kaydırmayı geçici olarak devre dışı bırakın"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тимчасово вимкнути плавне прокручування для підвищення точності прокручування"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暂时性地禁用平滑滚动以提高滚动精度"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暫時性地停用平滑捲動以提高捲動精度"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暫時性地停用平滑捲動以提高捲動精度"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
