    "2hV-f7-8yO.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Customize mouse buttons to enhance your experience\"; ObjectID = \"2hV-f7-8yO\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přizpůsobte si tlačítka myši pro pohodlnější ovládání"
