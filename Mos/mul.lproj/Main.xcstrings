    "v26-RK-BtL.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"The allow list mode will make Mos only apply to apps within the application list.\"; ObjectID = \"v26-RK-BtL\";",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V režimu povolených aplikací bude Mos aktivní pouze pro aplikace v tomto seznamu"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Allowlistmodus bewirkt, dass Mos nur für Anwendungen innerhalb der Ausnahmeliste gilt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The allow list mode will make Mos only apply to apps within the application list."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The allowlist mode will make Mos only apply to apps within the application list."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode liste autorisée fait que Mos ne s’applique qu’aux apps de la liste."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "許可リストモードは、このリストにあるアプリのみにMosを適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 모드는 Mos가 제외 목록 안의 앱만 설정하게 해줍니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Режим белого списка заставит Mos применяться только к приложениям из списка исключений."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beyaz liste modu, Mos'ın yalnızca istisna listesindeki uygulamalar için geçerli olmasını sağlar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Режим списку дозволених застосує Mos лише до програм у списку винятків."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用白名单模式后, Mos 仅会对包含在例外列表内的程序启用, 其他的则不受任何影响"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用白名單模式後，Mos 只會對例外列表中的應用程式啟用，其他不受影響"
          }
        },
