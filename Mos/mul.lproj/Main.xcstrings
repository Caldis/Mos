        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur eine kleine Aufgabe für Ihre Maus."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Απλά μια μικρή δουλειά για το ποντίκι σας."
