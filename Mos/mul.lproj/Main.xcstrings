        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passen Sie Maustasten an, um Ihr Erlebnis zu verbessern"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προσαρμόστε τα κουμπιά του ποντικιού για καλύτερη εμπειρία"
