    "5cx-xS-eRe.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Just some little job for your mouse.\"; ObjectID = \"5cx-xS-eRe\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Malý praktický nástroj pro vaší myš."
