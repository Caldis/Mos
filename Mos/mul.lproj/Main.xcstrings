    "yFl-4N-WcD.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Your mouse is about to get a smoothest scrolling experience.\\nPick up your mouse, we just have a few thing that you need to check.\"; ObjectID = \"yFl-4N-WcD\";",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaše myš získá plynulejší posouvání.\nNež začnete, je třeba nastavit několik věcí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Maus ist im Begriff, einen reibungslosen Bildlauf zu ermöglichen. \nHeben Sie Ihre Maus ab, wir haben nur ein paar Dinge, die Sie überprüfen müssen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your mouse is about to get a smoothest scrolling experience.\nPick up your mouse, we just have a few thing that you need to check."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your mouse is about to get a smoother scrolling experience.\nPick up your mouse, there are a few things you need to check."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre souris est sur le point de vous faire bénéficier d’une meilleure expérience de défilement. Munissez-vous d’elle, il y a d’abord quelques détails à vérifier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マウスのスクロールがよりスムーズになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러분의 마우스의 스크롤링을 더욱 부드럽게 해줍니다.\n마우스를 드신후에, 몇가지 확인할 사항을 알려드리겠습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша мышь готова к плавной прокрутке, но есть еще несколько важных моментов."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fareniz en akıcı bir kaydırma deneyimini yaşamak üzere.\nFarenizi alın, kontrol etmeniz gereken birkaç şeyimiz var."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша миша отримає найплавніше прокручування.\nВозьміть мишу, є кілька речей, які потрібно перевірити."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的鼠标即将获得顺滑的滚动体验\n由于 macOS 的限制, 应用需要辅助功能权限方可工作"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的滑鼠即將獲得順滑的滾動體驗，抓穩您的滑鼠！只有一些選項需要調整"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的滑鼠即將獲得順滑的滾動體驗，抓穩您的滑鼠！只有一些選項需要調整"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的滑鼠即將獲得順滑的滾動體驗，抓穩您的滑鼠！只有一些選項需要調整"
          }
        }
      }
    },
